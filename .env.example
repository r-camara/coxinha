# API keys used by the `genai` crate when the LLM provider is external.
# Not required — only fill in the ones you plan to use.
#
# Coxinha reads these from the environment. You can also export them
# from your shell profile (~/.bashrc, PowerShell $PROFILE, etc.).

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Ollama endpoint (default is localhost)
# OLLAMA_HOST=http://localhost:11434

# Log level
# RUST_LOG=coxinha=debug,info
